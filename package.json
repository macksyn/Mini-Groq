{
  "name": "groq-ai",
  "version": "6.0.0",
  "description": "High performance multi-device WhatsApp bot",
  "type": "module",
  "main": "dist/index.js",
  "directories": {
    "assets": "assets",
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },
  "scripts": {
    "start": "tsc && ([ -d assets ] && cp -r assets dist/ || true) && node dist/index.js",
    "start:optimized": "tsc && node --max-old-space-size=512 --optimize-for-size --gc-interval=100 dist/index.js",
    "start:fresh": "node dist/reset-data.js && node dist/index.js",
    "build": "tsc && ([ -d assets ] && cp -r assets dist/ || true)",
    "rebuild": "npm run clean && npm run build",
    "clean": "node -e \"import('fs').then(f=>f.default.rmSync('dist',{recursive:true,force:true}))\"",
    "dev": "tsc --watch & nodemon --watch dist --ext js dist/index.js",
    "setup": "npm run build && node dist/reset-data.js",
    "reset-data": "node dist/reset-data.js",
    "reset-session": "node -e \"import('fs').then(f=>f.default.rmSync('./session',{recursive:true,force:true})).then(()=>console.log('Session cleared!'))\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "audit": "npm audit --omit=dev",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "whatsapp-bot",
    "baileys-bot",
    "Groq-ai",
    "Suhail-Md",
    "multi-device",
    "nodejs-bot",
    "typescript-bot"
  ],
  "homepage": "https://github.com/macksyn/Mini-Groq",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macksyn/Mini-Groq.git"
  },
  "bugs": {
    "url": "https://github.com/macksyn/Mini-Groq/issues"
  },
  "license": "MIT",
  "author": "Alex Macksyn",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "acrcloud": "^1.4.0",
    "api-qasim": "^3.2.10",
    "awesome-phonenumber": "^5.11.0",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "file-type": "^19.6.0",
    "form-data": "^4.0.5",
    "gspeak": "^0.0.3",
    "human-readable": "^0.2.1",
    "libphonenumber-js": "^1.12.41",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.5.48",
    "mongoose": "^9.4.1",
    "mumaker": "^2.0.0",
    "mysql2": "^3.22.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "node-webpmux": "^3.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "ruhend-scraper": "^9.0.8",
    "sharp": "^0.34.5",
    "simple-git": "^3.36.0",
    "stickers-formatter": "^0.0.1",
    "syntax-error": "^1.4.0",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "madge": "^8.0.0",
    "nodemon": "^3.1.14",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "yargs-parser": "^21.1.1"
  }
}
